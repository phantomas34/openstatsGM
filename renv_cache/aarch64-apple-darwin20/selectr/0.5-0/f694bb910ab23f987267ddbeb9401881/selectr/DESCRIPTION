Package: selectr
Type: Package
Title: Translate CSS Selectors to XPath Expressions
Version: 0.5-0
Authors@R: c(person("Simon", "Potter", role = c("aut", "trl", "cre"), email = "simon@sjp.co.nz"), person("Simon", "Sapin", role = "aut"), person("Ian", "Bicking", role = "aut"))
